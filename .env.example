# Per-deployment configuration. Every tenant's deployment gets its own copy of this file
# pointed at the shared database, with its own TENANT_ID. See README.md for details.

# UUID of this deployment's tenant row (printed by `npm run provision-tenant`).
TENANT_ID=

# Shared Postgres database, used by every tenant deployment.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lab_platform

# Auth.js
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# S3-compatible object storage (AWS S3, Cloudflare R2, or MinIO for self-hosting).
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=lab-platform
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/lab-platform
